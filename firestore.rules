rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /challenges/{challengeId} {
      // Anyone authenticated can create a challenge
      allow create: if request.auth != null
                    && request.resource.data.creatorUid == request.auth.uid;

      // Creator or targeted challenger can read
      allow read: if request.auth != null
                  && (resource.data.creatorUid == request.auth.uid
                      || resource.data.challengerUid == request.auth.uid
                      || resource.data.challengerUid == null);

      // Creator updates their score; challenger updates their score + fills in their info
      allow update: if request.auth != null
                    && (resource.data.creatorUid == request.auth.uid
                        || resource.data.challengerUid == request.auth.uid
                        || resource.data.challengerUid == null);
    }

  }
}
